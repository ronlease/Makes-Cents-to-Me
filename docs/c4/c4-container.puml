@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Container Diagram - Makes Cents To Me

Person(user, "User", "Single local user")

System_Boundary(app, "Makes Cents To Me") {
    Container(web, "Angular Web App", "Angular 21", "Spending dashboard UI with institution/account management and CSV import wizard")
    Container(api, "API", "ASP.NET Core 10", "REST API providing institution, account, and import pipeline endpoints")
    ContainerDb(db, "Database", "PostgreSQL", "Stores institutions, accounts, import profiles, column mappings, and transactions")
}

System_Ext(claude, "Claude API", "Vendor normalization and categorization")

Rel(user, web, "Uses", "HTTP localhost")
Rel(web, api, "Calls", "HTTP/JSON")
Rel(api, db, "Reads/Writes", "EF Core")
Rel(api, claude, "Analyzes transactions", "HTTPS/JSON")

@enduml
